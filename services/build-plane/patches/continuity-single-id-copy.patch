+package fs
+
+import "testing"
+
+func TestLrailSingleIDCopySkipsOnlyFlattenedOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	skip, err := lrailSingleIDCopySkipsChown(0, 0)
+	if err != nil || !skip {
+		t.Fatalf("flattened ownership skip = %t, %v", skip, err)
+	}
+	for _, ids := range [][2]uint32{{1, 0}, {0, 1}, {10001, 10001}} {
+		if skip, err := lrailSingleIDCopySkipsChown(ids[0], ids[1]); err == nil || skip {
+			t.Fatalf("unexpected ownership %d:%d = %t, %v", ids[0], ids[1], skip, err)
+		}
+	}
+}
+
+func TestLrailSingleIDCopyLeavesOrdinaryOwnershipPathUnchanged(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "")
+	for _, ids := range [][2]uint32{{0, 0}, {1, 2}, {10001, 10001}} {
+		skip, err := lrailSingleIDCopySkipsChown(ids[0], ids[1])
+		if err != nil || skip {
+			t.Fatalf("ordinary ownership %d:%d = %t, %v", ids[0], ids[1], skip, err)
+		}
+	}
+}
