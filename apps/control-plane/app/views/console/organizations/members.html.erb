<% content_for :title, "Members · #{@organization.name} · Lrail" %><% content_for :breadcrumbs do %><span>Organization</span><strong>Members</strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow">Access control</p><h1>Members</h1><p class="page-header__description">Roles grant named actions. API scopes, environment policy, and entitlements can only restrict them further.</p></div><div class="page-header__actions"><button class="button button--primary">Invite member</button></div></header>
<div class="data-panel"><div class="data-panel__header"><h2><%= @organization.name %></h2><span><%= @organization_memberships.count %> members</span></div><div class="table-scroll"><table class="resource-table"><thead><tr><th>Account</th><th>Role</th><th>Status</th><th>Joined</th></tr></thead><tbody><% @organization_memberships.each do |membership| %><tr><td data-label="Account"><div class="table-primary"><span class="avatar avatar--small"><%= membership.account.display_name.first(2).upcase %></span><span><%= membership.account.display_name %><br><small><%= membership.account.email %></small></span></div></td><td data-label="Role"><%= membership.role.humanize %></td><td data-label="Status"><%= status_badge(membership.status == "active" ? "active" : membership.status) %></td><td data-label="Joined"><%= membership.created_at.to_date.to_fs(:long) %></td></tr><% end %></tbody></table></div></div>
