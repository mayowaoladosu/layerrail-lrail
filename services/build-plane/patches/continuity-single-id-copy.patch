+func lrailSingleIDCopySkipsChown(uid, gid uint32) (bool, error) {
+	if os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") != "true" {
+		return false, nil
+	}
+	// Every destination entry is created by logical root in this exact
+	// one-ID namespace and therefore already owns 0:0. Avoid an expensive
+	// no-op lchown per entry on Kata virtio-fs, but fail closed if a parent
+	// snapshot escaped the importer ownership flattening invariant.
+	if uid != 0 || gid != 0 {
+		return false, fmt.Errorf("strict single-ID snapshot contains unexpected ownership %d:%d", uid, gid)
+	}
+	return true, nil
+}
