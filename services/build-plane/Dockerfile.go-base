# syntax=docker/dockerfile:1.12
FROM golang:1.26.5-alpine@sha256:0178a641fbb4858c5f1b48e34bdaabe0350a330a1b1149aabd498d0699ff5fb2 AS upstream

# BuildKit's rootless native snapshotter copies every parent tree for each
# upstream layer. Flatten the exact pinned toolchain rootfs into one immutable
# layer so disposable Kata workers import the bytes once without changing them.
FROM scratch
COPY --from=upstream / /
ENV PATH="/usr/local/go/bin:/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
LABEL org.opencontainers.image.source="https://github.com/mayowaoladosu/layerrail-lrail" \
      org.opencontainers.image.licenses="BSD-3-Clause AND MIT AND Apache-2.0" \
      org.opencontainers.image.title="LayerRail flattened Go 1.26.5 Alpine build base" \
      dev.lrail.upstream.reference="docker.io/library/golang:1.26.5-alpine@sha256:0178a641fbb4858c5f1b48e34bdaabe0350a330a1b1149aabd498d0699ff5fb2"
USER 0:0
