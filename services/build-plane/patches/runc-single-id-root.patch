+#define LRAIL_SINGLE_ID 10001
+
+static bool lrail_single_id(void)
+{
+	const char *value = getenv("LRAIL_ROOTLESSKIT_SINGLE_ID");
+	return value != NULL && strcmp(value, "true") == 0;
+}
+
+static void verify_lrail_single_id_identity(void)
+{
+	uid_t ruid, euid, suid;
+	gid_t rgid, egid, sgid;
+	if (getresuid(&ruid, &euid, &suid) < 0 ||
+	    getresgid(&rgid, &egid, &sgid) < 0)
+		bail("failed to inspect strict single-ID credentials");
+	if (ruid != LRAIL_SINGLE_ID || euid != LRAIL_SINGLE_ID || suid != LRAIL_SINGLE_ID ||
+	    rgid != LRAIL_SINGLE_ID || egid != LRAIL_SINGLE_ID || sgid != LRAIL_SINGLE_ID)
+		bail("strict single-ID credentials differ from the exact logical identity");
+}
+
+static void restore_lrail_setup_capabilities(void)
+{
+	struct __user_cap_header_struct header = { _LINUX_CAPABILITY_VERSION_3, 0 };
+	struct __user_cap_data_struct data[_LINUX_CAPABILITY_U32S_3] = { 0 };
+	const unsigned int index = CAP_SYS_ADMIN / 32;
+	const __u32 mask = ((__u32) 1U) << (CAP_SYS_ADMIN % 32);
+	if (syscall(SYS_capget, &header, &data) < 0)
+		bail("failed to inspect strict single-ID setup capabilities");
+	if ((data[index].permitted & mask) == 0)
+		bail("strict single-ID namespace lacks permitted setup authority");
+	for (size_t i = 0; i < _LINUX_CAPABILITY_U32S_3; i++)
+		data[i].effective = data[i].permitted;
+	if (syscall(SYS_capset, &header, &data) < 0)
+		bail("failed to restore strict single-ID setup capabilities");
+}
+
+static pid_t lrail_procfs_pid(void)
+{
+	char path[64];
+	int pid, tid;
+	ssize_t length = readlink("/proc/thread-self", path, sizeof(path) - 1);
+	if (length <= 0 || (size_t) length >= sizeof(path))
+		bail("failed to translate strict single-ID process through procfs");
+	path[length] = '\0';
+	if (sscanf(path, "%d/task/%d", &pid, &tid) != 2 || pid <= 0 || pid != tid)
+		bail("strict single-ID procfs process identity is invalid");
+	return pid;
+}
