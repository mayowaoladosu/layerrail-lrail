<% content_for :title, "Usage · #{@organization.name} · Lrail" %><% content_for :breadcrumbs do %><span>Organization</span><strong>Usage</strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow">Reconciled metering</p><h1>Usage</h1><p class="page-header__description">Signed quantities become commercial truth only after sequence, gap, replay, and correction reconciliation.</p></div><div class="page-header__actions"><button class="button button--secondary">Export CSV</button></div></header>
<div class="metrics-strip"><div class="metric"><span class="metric__label">Plan</span><strong class="metric__value"><%= @organization.plan.capitalize %></strong><span class="metric__meta">Current entitlement</span></div><div class="metric"><span class="metric__label">Facts</span><strong class="metric__value"><%= @usage.count %></strong><span class="metric__meta">Recent ledger entries</span></div><div class="metric"><span class="metric__label">Corrections</span><strong class="metric__value"><%= @usage.count(&:correction_of_public_id?) %></strong><span class="metric__meta">Append-only</span></div><div class="metric"><span class="metric__label">Completeness</span><strong class="metric__value"><%= @usage.any? ? "Tracked" : "—" %></strong><span class="metric__meta">Per source watermark</span></div></div>
<div class="data-panel"><% if @usage.any? %><div class="table-scroll"><table class="resource-table"><thead><tr><th>Meter</th><th>Resource</th><th>Quantity</th><th>Period</th><th>Source</th></tr></thead><tbody><% @usage.each do |fact| %><tr><td data-label="Meter"><%= fact.meter_type.humanize %></td><td data-label="Resource" class="mono"><%= fact.resource_public_id.last(14) %></td><td data-label="Quantity"><%= number_with_delimiter(fact.quantity) %> <%= fact.unit %></td><td data-label="Period"><%= fact.period_start.to_fs(:short) %>–<%= fact.period_end.to_fs(:short) %></td><td data-label="Source" class="mono"><%= fact.source_id %>/<%= fact.sequence %></td></tr><% end %></tbody></table></div><% else %><div class="empty-state"><span class="empty-state__icon"><%= icon(:usage) %></span><h3>No reconciled usage yet</h3><p>Facts appear after trusted agents submit signed, sequential measurements.</p></div><% end %></div>
