+func lrailSingleIDChown(uid, gid int) (int, int, error) {
+	if os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") != "true" {
+		return uid, gid, nil
+	}
+	if uid < 0 || gid < 0 {
+		return 0, 0, fmt.Errorf("strict single-ID layer contains invalid ownership %d:%d", uid, gid)
+	}
+	return 0, 0, nil
+}
+
+func remapLrailSingleIDHeader(hdr *tar.Header) error {
+	if os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") != "true" {
+		return nil
+	}
+	if hdr.Uid != 0 || hdr.Gid != 0 {
+		return fmt.Errorf("strict single-ID layer contains unexpected ownership %d:%d", hdr.Uid, hdr.Gid)
+	}
+	hdr.Uid = 10001
+	hdr.Gid = 10001
+	return nil
+}
