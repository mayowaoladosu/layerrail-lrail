+
+func TestSingleIDMappings(t *testing.T) {
+	uids, gids, err := singleIDMappings(1000, 1000)
+	assert.NilError(t, err)
+	assert.DeepEqual(t, uids, []syscall.SysProcIDMap{{ContainerID: 0, HostID: 1000, Size: 1}})
+	assert.DeepEqual(t, gids, []syscall.SysProcIDMap{{ContainerID: 0, HostID: 1000, Size: 1}})
+}
+
+func TestSingleIDMappingsRejectsRoot(t *testing.T) {
+	_, _, err := singleIDMappings(1000, 1001)
+	if err == nil {
+		t.Fatal("expected root mapping to be rejected")
+	}
+}
