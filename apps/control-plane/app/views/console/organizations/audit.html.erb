<% content_for :title, "Audit log · #{@organization.name} · Lrail" %><% content_for :breadcrumbs do %><span>Organization</span><strong>Audit log</strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow">Immutable evidence</p><h1>Audit log</h1><p class="page-header__description">Sensitive and denied actions record actor, policy version, resource fingerprint, request, and outcome without copying secrets.</p></div><div class="page-header__actions"><button class="button button--secondary">Export evidence</button></div></header>
<div class="data-panel"><% if @events.any? %><div class="table-scroll"><table class="resource-table"><thead><tr><th>Action</th><th>Resource</th><th>Actor</th><th>Outcome</th><th>Request</th><th>Time</th></tr></thead><tbody><% @events.each do |event| %><tr><td data-label="Action"><strong><%= event.action %></strong></td><td data-label="Resource"><%= event.resource_type.humanize %><br><small class="mono"><%= event.resource_public_id.last(14) %></small></td><td data-label="Actor" class="mono"><%= event.actor_public_id&.last(12) || event.actor_type %></td><td data-label="Outcome"><%= status_badge(event.outcome == "succeeded" ? "succeeded" : event.outcome) %></td><td data-label="Request" class="mono"><%= event.request_id.last(12) %></td><td data-label="Time"><%= relative_time(event.occurred_at) %></td></tr><% end %></tbody></table></div><% else %><div class="empty-state"><span class="empty-state__icon"><%= icon(:audit) %></span><h3>No audit events</h3><p>Domain commands write audit evidence atomically with their customer-visible mutation.</p></div><% end %></div>
