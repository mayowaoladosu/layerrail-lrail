{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.lrail.dev/manifest/lrail.schema.json",
  "title": "lrail.yaml project manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "project", "services"],
  "properties": {
    "api_version": { "const": "lrail.dev/v1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "default_region": { "$ref": "#/$defs/name" }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/service" }
    },
    "addons": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/addon" }
    },
    "schedules": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/schedule" }
    }
  },
  "$defs": {
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
    "relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$",
      "maxLength": 1024
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "type": "string", "maxLength": 4096 }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root", "build", "processes"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "root": { "$ref": "#/$defs/relative_path" },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method"],
          "properties": {
            "method": { "enum": ["auto", "dockerfile", "starlark"] },
            "dockerfile": { "$ref": "#/$defs/relative_path" },
            "starlark": { "$ref": "#/$defs/relative_path" },
            "network": { "enum": ["none", "packages", "allowlist", "private"] }
          }
        },
        "processes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "command", "resources"],
            "properties": {
              "name": { "$ref": "#/$defs/name" },
              "kind": {
                "enum": [
                  "web",
                  "worker",
                  "private_service",
                  "release",
                  "job",
                  "static"
                ]
              },
              "command": { "$ref": "#/$defs/command" },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "health_path": {
                "type": "string",
                "pattern": "^/",
                "maxLength": 512
              },
              "runtime_class": { "enum": ["sandbox", "microvm", "native"] },
              "resources": {
                "type": "object",
                "additionalProperties": false,
                "required": ["profile"],
                "properties": {
                  "profile": {
                    "enum": ["nano", "small", "medium", "large", "xlarge"]
                  }
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "kind": { "enum": ["web", "private_service"] }
                  },
                  "required": ["kind"]
                },
                "then": { "properties": { "port": true }, "required": ["port"] }
              }
            ]
          }
        },
        "routes": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["process", "path"],
            "properties": {
              "process": { "$ref": "#/$defs/name" },
              "hostname": { "type": "string", "format": "hostname" },
              "path": { "type": "string", "pattern": "^/", "maxLength": 2048 }
            }
          }
        }
      }
    },
    "addon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "engine", "plan"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "engine": {
          "enum": [
            "postgresql",
            "mysql",
            "mariadb",
            "valkey",
            "mongodb",
            "opensearch",
            "clickhouse",
            "rabbitmq"
          ]
        },
        "plan": { "$ref": "#/$defs/name" },
        "deletion_protection": { "type": "boolean", "default": true }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cron", "timezone", "target", "overlap"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "cron": { "type": "string", "minLength": 5, "maxLength": 128 },
        "timezone": { "type": "string", "minLength": 1, "maxLength": 64 },
        "target": { "$ref": "#/$defs/name" },
        "overlap": {
          "enum": [
            "skip",
            "buffer_one",
            "queue_bounded",
            "cancel_previous",
            "allow_bounded"
          ]
        }
      }
    }
  }
}
