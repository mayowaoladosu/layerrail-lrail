<% content_for :title, "Deployments · #{@project.name} · Lrail" %>
<% content_for :breadcrumbs do %><span>Projects</span><%= link_to @project.name, console_organization_project_path(@organization.public_id, @project.public_id) %><strong>Deployments</strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow">Delivery history</p><h1>Deployments</h1><p class="page-header__description">Every source-to-revision attempt, including cancellation, failure, evidence, promotion, and cleanup.</p></div></header>
<div class="data-panel"><% if @deployments.any? %><div class="table-scroll"><table class="resource-table"><thead><tr><th>Deployment</th><th>Environment</th><th>Status</th><th>Stage</th><th>Progress</th><th>Created</th></tr></thead><tbody><% @deployments.each do |deployment| %><tr><td data-label="Deployment"><%= link_to console_organization_project_deployment_path(@organization.public_id, @project.public_id, deployment.public_id), class: "table-primary" do %><span class="commit-avatar"><%= deployment.source.fetch("commit", deployment.public_id).last(6) %></span><span><%= deployment.reason %><br><small class="mono"><%= deployment.public_id %></small></span><% end %></td><td data-label="Environment"><%= deployment.environment.name %></td><td data-label="Status"><%= status_badge(deployment.state) %></td><td data-label="Stage"><%= deployment.operation.stage.humanize %></td><td data-label="Progress"><%= deployment.operation.completed_steps %>/<%= deployment.operation.total_steps %></td><td data-label="Created"><%= relative_time(deployment.created_at) %></td></tr><% end %></tbody></table></div><% else %><div class="empty-state"><span class="empty-state__icon"><%= icon(:deploy) %></span><h3>No deployments</h3><p>Return to the project overview to accept an exact source commit.</p></div><% end %></div>
