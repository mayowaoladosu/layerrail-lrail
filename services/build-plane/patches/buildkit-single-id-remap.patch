+func TestParseIdentityMappingSingleID(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	mapping, err := parseIdentityMapping("")
+	require.NoError(t, err)
+	require.Equal(t, []user.IDMap{{ID: 10001, ParentID: 0, Count: 1}}, mapping.UIDMaps)
+	require.Equal(t, []user.IDMap{{ID: 10001, ParentID: 0, Count: 1}}, mapping.GIDMaps)
+}
+
+func TestParseIdentityMappingSingleIDRejectsOtherRemap(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	_, err := parseIdentityMapping("user")
+	require.Error(t, err)
+}
+
+func TestParseIdentityMappingDefaultIsUnchanged(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "")
+	mapping, err := parseIdentityMapping("")
+	require.NoError(t, err)
+	require.Nil(t, mapping)
+}
