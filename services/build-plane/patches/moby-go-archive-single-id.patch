+func resolveLrailChownOpts(chownOpts *ChownOpts, hdr *tar.Header) *ChownOpts {
+	if os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") == "true" {
+		return &ChownOpts{UID: 0, GID: 0}
+	}
+	if chownOpts != nil {
+		return chownOpts
+	}
+	return &ChownOpts{UID: hdr.Uid, GID: hdr.Gid}
+}
