@@ -0,0 +1,32 @@
+package oci
+
+import (
+	"slices"
+	"testing"
+)
+
+func TestDefaultMountsDevptsGID(t *testing.T) {
+	tests := []struct {
+		name     string
+		singleID string
+		expected string
+	}{
+		{name: "subordinate IDs", expected: "gid=5"},
+		{name: "single ID", singleID: "true", expected: "gid=10001"},
+	}
+	for _, test := range tests {
+		t.Run(test.name, func(t *testing.T) {
+			t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", test.singleID)
+			for _, mount := range defaultMounts() {
+				if mount.Destination != "/dev/pts" {
+					continue
+				}
+				if !slices.Contains(mount.Options, test.expected) {
+					t.Fatalf("devpts options = %#v", mount.Options)
+				}
+				return
+			}
+			t.Fatal("devpts mount is absent")
+		})
+	}
+}
