 				bail("setgid failed");
@@ -1188,5 +1201,5 @@ void nsexec(void)
 
-			if (!config.is_rootless_euid && config.is_setgroup) {
+			if (!config.is_rootless_euid && config.is_setgroup && !lrail_single_id()) {
