--- a/libcontainer/nsenter/nsexec.c
+++ b/libcontainer/nsenter/nsexec.c
@@ -49,5 +49,18 @@ enum sync_t {
 /* Stores the current stage of nsexec. */
 int current_stage = STAGE_SETUP;
 
+#define LRAIL_SINGLE_ID 10001
+
+static bool lrail_single_id(void)
+{
+	const char *value = getenv("LRAIL_ROOTLESSKIT_SINGLE_ID");
+	return value != NULL && strcmp(value, "true") == 0;
+}
+
+static uid_t namespace_root_id(void)
+{
+	return lrail_single_id() ? LRAIL_SINGLE_ID : 0;
+}
+
 /* Assume the stack grows down, so arguments should be above it. */
 struct clone_t {
@@ -541,7 +554,7 @@ static nsset_t __join_namespaces(nsset_t allow, struct namespace_t *ns_list, siz
