<% content_for :title, "#{@service.name} · #{@project.name} · Lrail" %>
<% content_for :breadcrumbs do %><span>Projects</span><%= link_to @project.name, console_organization_project_path(@organization.public_id, @project.public_id) %><span>Services</span><strong><%= @service.name %></strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow"><%= status_badge(@service.health) %> <%= @service.kind.humanize %></p><h1><%= @service.name %></h1><p class="page-header__description"><%= @service.framework.presence || "Custom runtime" %> · <span class="mono"><%= @service.public_id %></span></p></div><div class="page-header__actions"><button class="button button--secondary">Open logs</button><button class="button button--primary">Deploy service</button></div></header>
<nav class="context-bar resource-tabs"><a class="is-active" href="#overview">Overview</a><a href="#deployments">Deployments</a><a href="#releases">Releases</a><a href="#configuration">Configuration</a><a href="#scaling">Scaling</a><a href="#routes">Routes</a><a href="#metrics">Metrics</a></nav>
<div class="metrics-strip"><div class="metric"><span class="metric__label">Health</span><strong class="metric__value"><%= @service.health.humanize %></strong><span class="metric__meta">Current observation</span></div><div class="metric"><span class="metric__label">Releases</span><strong class="metric__value"><%= @releases.count %></strong><span class="metric__meta">Retained history</span></div><div class="metric"><span class="metric__label">Revisions</span><strong class="metric__value"><%= @revisions.count %></strong><span class="metric__meta">Immutable artifacts</span></div><div class="metric"><span class="metric__label">Runtime</span><strong class="metric__value"><%= @service.runtime_specification.fetch("profile", "—") %></strong><span class="metric__meta">Resolved profile</span></div></div>
<div class="split-layout"><section class="data-panel"><div class="data-panel__header"><h2>Release history</h2></div><% if @releases.any? %><div class="table-scroll"><table class="resource-table"><thead><tr><th>Release</th><th>Environment</th><th>Status</th><th>Traffic</th><th>Created</th></tr></thead><tbody><% @releases.each do |release| %><tr><td data-label="Release" class="mono"><%= release.public_id.last(14) %></td><td data-label="Environment"><%= release.environment.name %></td><td data-label="Status"><%= status_badge(release.state) %></td><td data-label="Traffic"><%= release.traffic_weight %>%</td><td data-label="Created"><%= relative_time(release.created_at) %></td></tr><% end %></tbody></table></div><% else %><div class="empty-state"><span class="empty-state__icon"><%= icon(:deploy) %></span><h3>No releases</h3><p>A release is created from a verified immutable revision.</p></div><% end %></section><aside class="detail-stack"><div class="data-panel"><div class="data-panel__header"><h2>Runtime specification</h2></div><dl class="kv-list"><% @service.runtime_specification.presence&.each do |key, value| %><div><dt><%= key.humanize %></dt><dd><%= value %></dd></div><% end %><% if @service.runtime_specification.blank? %><div><dt>State</dt><dd>Not configured</dd></div><% end %></dl></div><div class="data-panel"><div class="data-panel__header"><h2>Build specification</h2></div><dl class="kv-list"><% @service.build_specification.presence&.each do |key, value| %><div><dt><%= key.humanize %></dt><dd><%= value %></dd></div><% end %><% if @service.build_specification.blank? %><div><dt>Detector</dt><dd>Awaiting source</dd></div><% end %></dl></div></aside></div>
