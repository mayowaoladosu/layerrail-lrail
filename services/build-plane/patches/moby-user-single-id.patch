+package user
+
+import "testing"
+
+func TestLrailSingleIDMappingAliasesFilesystemRoot(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	mapping := IdentityMapping{
+		UIDMaps: []IDMap{{ID: 10001, ParentID: 0, Count: 1}},
+		GIDMaps: []IDMap{{ID: 10001, ParentID: 0, Count: 1}},
+	}
+	for _, ids := range [][2]int{{0, 0}, {10001, 10001}} {
+		uid, gid, err := mapping.ToHost(ids[0], ids[1])
+		if err != nil || uid != 0 || gid != 0 {
+			t.Fatalf("ToHost(%d, %d) = %d, %d, %v", ids[0], ids[1], uid, gid, err)
+		}
+	}
+	uid, gid, err := mapping.ToContainer(0, 0)
+	if err != nil || uid != 10001 || gid != 10001 {
+		t.Fatalf("ToContainer(0, 0) = %d, %d, %v", uid, gid, err)
+	}
+}
+
+func TestLrailSingleIDMappingRequiresExactShape(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	if _, err := toHost(0, []IDMap{{ID: 10002, ParentID: 0, Count: 1}}); err == nil {
+		t.Fatal("unexpected root alias for a different mapping")
+	}
+}
