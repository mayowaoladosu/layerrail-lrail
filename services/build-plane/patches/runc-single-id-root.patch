 					bail("failed to become root in user namespace");
 			}
 
@@ -1180,8 +1193,8 @@ void nsexec(void)
 			if (setsid() < 0)
 				bail("setsid failed");
 
-			if (setuid(0) < 0)
+			if (setuid(namespace_root_id()) < 0)
