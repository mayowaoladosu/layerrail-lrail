+++ b/archive_lrail_test.go
@@ -0,0 +1,60 @@
+package archive
+
+import (
+	"bytes"
+	"archive/tar"
+	"os"
+	"syscall"
+	"testing"
+)
+
+func TestLrailResolveChownOptsFlattensImageOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	header := &tar.Header{Uid: 0, Gid: 42}
+	for _, input := range []*ChownOpts{nil, {UID: 10001, GID: 65534}} {
+		actual := resolveLrailChownOpts(input, header)
+		if actual.UID != 0 || actual.GID != 0 {
+			t.Fatalf("chown identity = %d:%d", actual.UID, actual.GID)
+		}
+	}
+}
+
+func TestLrailResolveChownOptsLeavesDefaultModeUnchanged(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "")
+	header := &tar.Header{Uid: 12, Gid: 42}
+	actual := resolveLrailChownOpts(nil, header)
+	if actual.UID != 12 || actual.GID != 42 {
+		t.Fatalf("header identity = %d:%d", actual.UID, actual.GID)
+	}
+	explicit := &ChownOpts{UID: 4, GID: 8}
+	if actual = resolveLrailChownOpts(explicit, header); actual != explicit {
+		t.Fatal("explicit ownership was replaced")
+	}
+}
+
+func TestLrailSingleIDUntarFlattensImageOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	var contents bytes.Buffer
+	writer := tar.NewWriter(&contents)
+	if err := writer.WriteHeader(&tar.Header{Name: "owned", Mode: 0o600, Size: 1, Uid: 0, Gid: 42}); err != nil {
+		t.Fatal(err)
+	}
+	if _, err := writer.Write([]byte("x")); err != nil {
+		t.Fatal(err)
+	}
+	if err := writer.Close(); err != nil {
+		t.Fatal(err)
+	}
+	destination := t.TempDir()
+	if err := Untar(bytes.NewReader(contents.Bytes()), destination, &TarOptions{}); err != nil {
+		t.Fatal(err)
+	}
+	info, err := os.Lstat(destination + "/owned")
+	if err != nil {
+		t.Fatal(err)
+	}
+	stat := info.Sys().(*syscall.Stat_t)
+	if stat.Uid != 0 || stat.Gid != 0 {
+		t.Fatalf("extracted identity = %d:%d", stat.Uid, stat.Gid)
+	}
+}
