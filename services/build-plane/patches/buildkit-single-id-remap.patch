diff --git a/cmd/buildkitd/util_linux.go b/cmd/buildkitd/util_linux.go
index 251b3ad..4e2c831 100644
--- a/cmd/buildkitd/util_linux.go
+++ b/cmd/buildkitd/util_linux.go
@@ -1,14 +1,25 @@
 package main
 
 import (
+	"os"
 	"strings"
 
 	"github.com/moby/buildkit/util/bklog"
 	"github.com/moby/sys/user"
 	"github.com/pkg/errors"
 )
 
 func parseIdentityMapping(str string) (*user.IdentityMapping, error) {
+	if os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") == "true" {
+		if str != "" {
+			return nil, errors.New("single-ID rootless mode conflicts with configured user remapping")
+		}
+		mapping := user.IDMap{ID: 10001, ParentID: 0, Count: 1}
+		return &user.IdentityMapping{
+			UIDMaps: []user.IDMap{mapping},
+			GIDMaps: []user.IDMap{mapping},
+		}, nil
+	}
 	if str == "" {
 		return nil, nil
 	}
