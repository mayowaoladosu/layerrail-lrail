@@ -51,8 +52,16 @@ func (c Config) HostUID(containerId int) (int, error) {
 	return containerId, nil
 }
 
+func IsLrailSingleIDMap(mappings []IDMap) bool {
+	return os.Getenv("LRAIL_ROOTLESSKIT_SINGLE_ID") == "true" && len(mappings) == 1 &&
+		mappings[0] == (IDMap{ContainerID: 10001, HostID: 0, Size: 1})
+}
+
 // HostRootUID gets the root uid for the process on host which could be non-zero
 // when user namespaces are enabled.
 func (c Config) HostRootUID() (int, error) {
+	if c.Namespaces.Contains(NEWUSER) && IsLrailSingleIDMap(c.UIDMappings) {
+		return 0, nil
+	}
 	return c.HostUID(0)
 }
@@ -81,5 +90,8 @@ func (c Config) HostGID(containerId int) (int, error) {
 // HostRootGID gets the root gid for the process on host which could be non-zero
 // when user namespaces are enabled.
 func (c Config) HostRootGID() (int, error) {
+	if c.Namespaces.Contains(NEWUSER) && IsLrailSingleIDMap(c.GIDMappings) {
+		return 0, nil
+	}
 	return c.HostGID(0)
 }
diff --git a/libcontainer/configs/config_linux_test.go b/libcontainer/configs/config_linux_test.go
index 4a8461f..8688c16 100644
--- a/libcontainer/configs/config_linux_test.go
+++ b/libcontainer/configs/config_linux_test.go
@@ -78,3 +78,28 @@ func TestHostRootGIDWithUSERNS(t *testing.T) {
 		t.Fatalf("expected gid 1000 with no USERNS but received %d", uid)
 	}
 }
+
+func TestHostRootIDsWithLrailSingleIDMapping(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	config := &Config{
+		Namespaces: Namespaces{{Type: NEWUSER}},
+		UIDMappings: []IDMap{{ContainerID: 10001, HostID: 0, Size: 1}},
+		GIDMappings: []IDMap{{ContainerID: 10001, HostID: 0, Size: 1}},
+	}
+	uid, uidErr := config.HostRootUID()
+	gid, gidErr := config.HostRootGID()
+	if uidErr != nil || gidErr != nil || uid != 0 || gid != 0 {
+		t.Fatalf("host root IDs = %d, %d, %v, %v", uid, gid, uidErr, gidErr)
+	}
+}
+
+func TestHostRootIDsRequireExactLrailSingleIDMapping(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	config := &Config{
+		Namespaces: Namespaces{{Type: NEWUSER}},
+		UIDMappings: []IDMap{{ContainerID: 10002, HostID: 0, Size: 1}},
+	}
+	if _, err := config.HostRootUID(); err == nil {
+		t.Fatal("unexpected root alias for a different mapping")
+	}
+}
