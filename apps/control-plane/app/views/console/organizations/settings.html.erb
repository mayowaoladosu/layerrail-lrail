<% content_for :title, "Settings · #{@organization.name} · Lrail" %><% content_for :breadcrumbs do %><span>Organization</span><strong>Settings</strong><% end %>
<header class="page-header"><div><p class="page-header__eyebrow">Workspace policy</p><h1>Organization settings</h1><p class="page-header__description">Identity, source providers, notifications, API credentials, retention, and policy remain scoped to <%= @organization.name %>.</p></div></header>
<div class="split-layout"><section class="detail-stack"><div class="data-panel"><div class="data-panel__header"><h2>General</h2></div><div class="onboarding-panel__form"><div class="form-stack"><div class="field"><label>Name</label><input value="<%= @organization.name %>" disabled></div><div class="field"><label>Slug</label><input value="<%= @organization.slug %>" disabled></div><div class="field"><label>Plan</label><input value="<%= @organization.plan.capitalize %>" disabled></div></div><div class="form-actions"><button class="button button--primary" disabled>Save changes</button></div></div></div><div class="data-panel danger-zone"><div class="data-panel__header"><h2>Deletion protection</h2></div><div class="panel-copy"><p class="page-header__description">Organization deletion inventories and retires every route, workload, credential, object, backup, and legal hold through a durable workflow.</p><button class="button button--danger" disabled>Request deletion</button></div></div></section><aside class="detail-stack"><div class="data-panel"><div class="data-panel__header"><h2>Connections</h2></div><dl class="kv-list"><div><dt>Git providers</dt><dd>Not connected</dd></div><div><dt>Notifications</dt><dd>Email</dd></div><div><dt>API credentials</dt><dd>0 active</dd></div><div><dt>Webhooks</dt><dd><%= @organization.webhooks.count %> configured</dd></div></dl></div><div class="data-panel"><div class="data-panel__header"><h2>Identifiers</h2></div><dl class="kv-list"><div><dt>Organization ID</dt><dd class="mono"><%= @organization.public_id %></dd></div><div><dt>Role</dt><dd><%= current_membership.role.humanize %></dd></div><div><dt>Created</dt><dd><%= @organization.created_at.to_date.to_fs(:long) %></dd></div></dl></div></aside></div>
