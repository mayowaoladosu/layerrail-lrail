diff --git a/pkg/archive/tar_lrail_test.go b/pkg/archive/tar_lrail_test.go
new file mode 100644
index 0000000..46a98d9
--- /dev/null
+++ b/pkg/archive/tar_lrail_test.go
@@ -0,0 +1,60 @@
+package archive
+
+import (
+	"archive/tar"
+	"testing"
+)
+
+func TestRemapLrailSingleIDHeader(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	header := &tar.Header{Uid: 0, Gid: 0}
+	if err := remapLrailSingleIDHeader(header); err != nil {
+		t.Fatal(err)
+	}
+	if header.Uid != 10001 || header.Gid != 10001 {
+		t.Fatalf("header identity = %d:%d", header.Uid, header.Gid)
+	}
+}
+
+func TestLrailSingleIDChownFlattensImageOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	for _, ids := range [][2]int{{0, 0}, {0, 42}, {10001, 10001}, {65534, 65534}} {
+		uid, gid, err := lrailSingleIDChown(ids[0], ids[1])
+		if err != nil || uid != 0 || gid != 0 {
+			t.Fatalf("lrailSingleIDChown(%d, %d) = %d, %d, %v", ids[0], ids[1], uid, gid, err)
+		}
+	}
+}
+
+func TestLrailSingleIDChownRejectsNegativeOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	if _, _, err := lrailSingleIDChown(-1, 0); err == nil {
+		t.Fatal("negative ownership unexpectedly flattened")
+	}
+}
+
+func TestLrailSingleIDChownLeavesDefaultModeUnchanged(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "")
+	uid, gid, err := lrailSingleIDChown(12, 42)
+	if err != nil || uid != 12 || gid != 42 {
+		t.Fatalf("lrailSingleIDChown(12, 42) = %d, %d, %v", uid, gid, err)
+	}
+}
+
+func TestRemapLrailSingleIDHeaderRejectsUnexpectedOwnership(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "true")
+	if err := remapLrailSingleIDHeader(&tar.Header{Uid: 1, Gid: 0}); err == nil {
+		t.Fatal("expected unexpected ownership to fail")
+	}
+}
+
+func TestRemapLrailSingleIDHeaderLeavesDefaultModeUnchanged(t *testing.T) {
+	t.Setenv("LRAIL_ROOTLESSKIT_SINGLE_ID", "")
+	header := &tar.Header{Uid: 1, Gid: 2}
+	if err := remapLrailSingleIDHeader(header); err != nil {
+		t.Fatal(err)
+	}
+	if header.Uid != 1 || header.Gid != 2 {
+		t.Fatalf("header identity = %d:%d", header.Uid, header.Gid)
+	}
+}
